---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="ZeroClue">
  <style>
    .intro { margin: 2.5rem 0 3rem; }
    .intro p { font-size: 1.05rem; color: var(--text-muted); margin: 0; }
    .section-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      margin: 0 0 2rem;
    }
  </style>
  <div class="intro">
    <p>
      Software architect. Building
      <a href="https://kern.web.za">Kern</a>,
      <a href="https://coolminds.co.za">CoolMinds</a>, and
      <a href="https://mftplus.co.za">MFTPlus</a>.
      Writing here.
    </p>
  </div>
  {posts.length > 0 && (
    <>
      <p class="section-label">Writing</p>
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          slug={post.slug}
          description={post.data.description}
        />
      ))}
    </>
  )}
</Base>
