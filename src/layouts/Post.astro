---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;

const formatted = date.toLocaleDateString('en-ZA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} — ZeroClue`} description={description}>
  <style>
    .post-header { margin: 2rem 0 2.5rem; }
    .post-title {
      font-size: 1.75rem;
      font-weight: 600;
      letter-spacing: -0.03em;
      line-height: 1.25;
      margin: 0 0 0.5rem;
    }
    .post-meta { color: var(--text-muted); font-size: 0.875rem; margin: 0; }
    .post-body h2 { font-size: 1.25rem; margin-top: 2.5rem; letter-spacing: -0.02em; }
    .post-body h3 { font-size: 1.05rem; margin-top: 2rem; }
    .post-body p { margin: 1.25rem 0; }
    .post-body ul, .post-body ol { padding-left: 1.5rem; }
    .post-body li { margin: 0.4rem 0; }
    .post-body blockquote {
      border-left: 3px solid var(--border);
      margin: 1.5rem 0;
      padding: 0.25rem 1rem;
      color: var(--text-muted);
    }
    .back {
      display: block;
      margin-top: 3rem;
      color: var(--text-muted);
      font-size: 0.875rem;
      text-decoration: none;
    }
    .back:hover { color: var(--text); opacity: 1; }
  </style>
  <article>
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <p class="post-meta">{formatted}</p>
    </header>
    <div class="post-body">
      <slot />
    </div>
  </article>
  <a href="/" class="back">← All posts</a>
</Base>
